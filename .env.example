PORT=3000
FETCH_EVERY_MINUTES=60

# LLM 설정 (AI 요약 기능)
# LLM_PROVIDER: "gemini" 또는 "lmstudio"
LLM_PROVIDER=lmstudio

# Gemini API (LLM_PROVIDER=gemini 사용 시)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# LM Studio API (LLM_PROVIDER=lmstudio 사용 시)
LMSTUDIO_URL=http://100.71.81.27:8899/v1
LMSTUDIO_MODEL=qwen2.5-32b-instruct
LMSTUDIO_TEMPERATURE=0.3
LMSTUDIO_MAX_TOKENS=500
LMSTUDIO_MAX_CONTEXT_LENGTH=8000
LMSTUDIO_TIMEOUT=700000
