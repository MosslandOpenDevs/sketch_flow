PORT=3000

# 수집 주기(분). 60을 나누어떨어지는 값 권장 (예: 15, 30, 60).
FETCH_EVERY_MINUTES=60

# 한 번의 수집에서 요약할 최대 항목 수 (첫 실행 폭주 방지)
MAX_ITEMS_PER_FETCH=25

# 설정 시 POST /fetch 호출에 x-fetch-token 헤더가 필요합니다. 비워두면 인증 없음.
FETCH_TOKEN=

# LLM 설정 (AI 요약 기능)
# LLM_PROVIDER: "gemini" 또는 "lmstudio" (미설정 시 gemini)
LLM_PROVIDER=gemini

# Gemini API (LLM_PROVIDER=gemini 사용 시)
# 키가 없어도 서버는 실행되며, 요약 자리에 안내 문구가 채워집니다.
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# LM Studio API (LLM_PROVIDER=lmstudio 사용 시)
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5-32b-instruct
LMSTUDIO_TEMPERATURE=0.3
LMSTUDIO_MAX_TOKENS=500
LMSTUDIO_MAX_CONTEXT_LENGTH=8000
LMSTUDIO_TIMEOUT=120000
